SECRET_KEY=CHANGE-ME-generate-with-python-c-import-secrets-print-secrets-token-urlsafe-64
ENV=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Runtime URL — used by the app. Point at the transaction pooler (port 6543)
# for Supabase; asyncpg is configured with statement_cache_size=0 for pgbouncer
# compatibility.
DATABASE_URL=postgresql+asyncpg://postgres.REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres

# Direct connection URL — used by Alembic for DDL migrations only.
# The transaction pooler (port 6543) silently discards DDL, so migrations
# must bypass pgbouncer. env.py auto-derives this from DATABASE_URL for
# standard Supabase setups (db.REF.supabase.co:5432); set it explicitly
# here when auto-derivation fails (custom domains, non-standard hostnames).
# Get it from: Supabase Dashboard → Project Settings → Database → Direct connection.
DIRECT_DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.REF.supabase.co:5432/postgres

DB_SCHEMA=async-pulse

# ── Auth ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
